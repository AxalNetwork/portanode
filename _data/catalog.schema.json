{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axal.dev/schemas/catalog.schema.json",
  "title": "AXAL product catalog",
  "type": "object",
  "required": ["version", "currency", "modules", "regions"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "currency": { "type": "string", "enum": ["USD", "EUR", "GBP"] },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/region" }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/module" }
    }
  },
  "definitions": {
    "region": {
      "type": "object",
      "required": ["id", "name", "freightTier"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "freightTier": { "type": "integer", "minimum": 1, "maximum": 3 },
        "leadTimeAdderWeeks": { "type": "integer", "minimum": 0 }
      }
    },
    "module": {
      "type": "object",
      "required": [
        "id", "name", "sku", "category", "basePrice", "currency",
        "dimensions", "weight", "power", "leadTimeWeeks", "regions",
        "options", "interconnects"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "basePrice": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP"] },
        "dimensions": {
          "type": "object",
          "required": ["form", "lengthFt"],
          "additionalProperties": false,
          "properties": {
            "form": { "type": "string", "enum": ["10ft", "20ft", "20ft-HC", "40ft", "40ft-HC"] },
            "lengthFt": { "type": "number", "minimum": 0 },
            "widthFt": { "type": "number", "minimum": 0 },
            "heightFt": { "type": "number", "minimum": 0 }
          }
        },
        "weight": {
          "type": "object",
          "required": ["kg"],
          "additionalProperties": false,
          "properties": {
            "kg": { "type": "number", "minimum": 0 },
            "displayTons": { "type": "string" }
          }
        },
        "power": {
          "type": "object",
          "required": ["drawKw"],
          "additionalProperties": false,
          "properties": {
            "drawKw": { "type": "number" },
            "generationKw": { "type": "number", "minimum": 0 },
            "storageKwh": { "type": "number", "minimum": 0 }
          }
        },
        "leadTimeWeeks": { "type": "integer", "minimum": 1 },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        },
        "interconnects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["targetModuleId", "type"],
            "additionalProperties": false,
            "properties": {
              "targetModuleId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
              "type": { "type": "string", "enum": ["power", "data", "fluid", "thermal"] },
              "required": { "type": "boolean", "default": false }
            }
          }
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/definitions/option" }
        }
      }
    },
    "option": {
      "type": "object",
      "required": [
        "id", "name", "category", "default",
        "priceDelta", "weightDelta", "powerDelta",
        "requires", "excludes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "default": { "type": "boolean" },
        "priceDelta": { "type": "number" },
        "weightDelta": { "type": "number" },
        "powerDelta": { "type": "number" },
        "requires": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        },
        "excludes": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        }
      }
    }
  }
}
