{
  "name": "axal-site",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/tailwind.css --watch",
    "validate:catalog": "node scripts/validate-catalog.js",
    "prebuild:css": "node scripts/validate-catalog.js",
    "build:configurator": "cd configurator && npm install && npm run build",
    "build:account": "cd account && npm install && npm run build"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "tailwindcss": "^3.4.13"
  }
}
